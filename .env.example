ENVIRONMENT=development

DATABASE_URL=postgresql://quizapp:quizapp@postgres:5432/quizapp

SECRET_KEY=change-me
REFRESH_SECRET_KEY=change-me-too

CORS_ORIGINS=http://localhost:8000

FRONTEND_URL=http://localhost:8000

ALLOWED_HOSTS=localhost,127.0.0.1

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
ADMIN_EMAILS=admin@example.com

# SMTP — LEGACY (não utilizado em modo demo)
# O sistema opera sem SMTP. Recuperação de senha via reset_url na própria API.
# As variáveis abaixo são mantidas para referência, mas não são necessárias:
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@quizapp.com
# SMTP_USE_TLS=true
# SMTP_TIMEOUT=30